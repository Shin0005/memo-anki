{
  "name": "@memo-anki/shared",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "generate": "openapi-typescript openapi.json -o src/api.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.7.2"
  }
}
