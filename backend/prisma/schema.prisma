generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

// 現在のバージョンではurlの機能はサポートされているため、エラーを無視。
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * 全体の関係として、User -> Deck -> Cardという関係
 * UserはDeckに所属しないCardを持たない。
 */

// Userテーブル
model User {
  id                    String    @id @default(uuid())
  username              String    @unique
  email                 String?   @unique
  passwordHash          String
  refreshTokenHash      String?
  refreshTokenExpiresAt DateTime? // refreshToken有効期限
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  decks                 Deck[]

  @@map("users")
}

// Deckテーブル
model Deck {
  id          BigInt   @id @default(autoincrement()) //uuidは過剰
  userId      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([userId])
  @@map("decks")
}

// Cardテーブル
/**
 * type  =  {0:note, 1:quiz}
 * queue =  {0:NEW, 1: SHORT, 2:LONG}
 */

model Card {
  id           BigInt   @id @default(autoincrement()) // 漏洩しても問題ない
  deckId       BigInt
  name         String
  /// Cardの種類：noteかquiz
  type         Int
  content      String? // noteの時の内容 quizの時null
  question     String? // quizの時の質問 noteの時null
  answer       String? // quizの時の回答 noteの時null
  /// queueの種類：NEW，SHORT，LONG
  queue        Int      @default(0)
  /// 復習回数
  repetition   Int      @default(0)
  /// 復習間隔
  interval     Int      @default(1)
  /// 難易度係数
  easeFactor   Float    @default(2.5)
  /// 次回復習日時
  nextReviewAt DateTime @default(now())
  version      Int      @default(0) // 複数ワーカー対策
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  // デッキごとのカード取得を高速化
  @@index([deckId])
  @@map("card")
}
