# DB 接続文字列（Docker Compose 環境ではホスト名 `db`、ホストから直接接続する場合は `localhost`）
DATABASE_URL="postgresql://user:password@db:5432/memoanki"

# JWT 署名鍵：openssl rand -hex 32 で生成した値を設定
JWT_SECRET=""

NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"

